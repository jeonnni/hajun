# =====================================================================
# .env.example — 백엔드 환경변수 템플릿
# 이 파일을 복사해서 .env 로 만들고 실제 값을 채워넣으세요:
#   cp .env.example .env
# =====================================================================

# MySQL 연결 URL
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/photogallery

# 관리자 페이지 비밀번호 (x-admin-key 헤더로 전달)
ADMIN_KEY=admin123

# JWT 시크릿
SECRET_KEY=your_secret_key_here

# AWS S3
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=ap-northeast-2
S3_BUCKET_NAME=your_bucket_name

# CloudFront (없으면 S3 직접 URL 사용)
CLOUDFRONT_URL=https://your_cloudfront_domain.cloudfront.net
